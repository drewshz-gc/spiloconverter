# Jira Configuration
# Copy this file to .env and fill in your credentials.
# Auth: HTTP Basic with "<email>:<api_token>" (base64) against the base URL.

# Jira Base URL
DBX_JIRA_BASE_URL="https://guidecom.atlassian.net"

# Your Atlassian account email
DBX_JIRA_EMAIL=""

# Your Jira API token (create at: https://id.atlassian.com/manage-profile/security/api-tokens)
DBX_JIRA_TOKEN=""
