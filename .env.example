# Jira Configuration
# Copy this file to .env and fill in your credentials.
# Auth: HTTP Basic with "<email>:<api_token>" (base64) against the base URL.

# Jira Base URL
DBX_JIRA_BASE_URL="https://guidecom.atlassian.net"

# Your Atlassian account email
DBX_JIRA_EMAIL=""

# Your Jira API token (create at: https://id.atlassian.com/manage-profile/security/api-tokens)
DBX_JIRA_TOKEN=""

# --- Confluence Configuration ---
# Confluence Cloud shares your Atlassian account, so the same API token works.
# REST base is the Jira domain plus "/wiki".

# Confluence Base URL (Jira domain + /wiki)
DBX_CONFLUENCE_BASE_URL="https://guidecom.atlassian.net/wiki"

# Your Atlassian account email
DBX_CONFLUENCE_EMAIL=""

# Your Confluence/Atlassian API token (create at: https://id.atlassian.com/manage-profile/security/api-tokens)
DBX_CONFLUENCE_TOKEN=""
